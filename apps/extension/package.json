{
  "name": "@unwrap/extension",
  "version": "0.1.0",
  "description": "Unwrap — Chrome extension that captures sessions for QA test generation and site reconstruction.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
