{
  "name": "unwrap",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension that captures sessions (network, screenshots, navigation, storage) for QA test generation and site reconstruction, with an LLM-backed test generator running on Cloudflare Workers.",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "dev:extension": "pnpm --filter @unwrap/extension dev",
    "dev:server": "pnpm --filter @unwrap/server dev",
    "build:extension": "pnpm --filter @unwrap/extension build",
    "build:server": "pnpm --filter @unwrap/server build",
    "deploy:server": "pnpm --filter @unwrap/server deploy"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "overrides": {
      "rollup": "^4.34.0",
      "esbuild": "^0.25.0"
    }
  }
}
